rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow get, list: if request.auth != null && userId == request.auth.uid;
      allow create: if request.auth != null && userId == request.auth.uid;
      allow update: if request.auth != null && userId == request.auth.uid 
                   && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['settings', 'displayName', 'photoURL']);
      allow delete: if false;
    }

    match /workspaces/{workspaceId} {
      allow get: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow list: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && resource.data.ownerId == request.auth.uid 
                   && request.resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;

      match /messages/{messageId} {
        allow get: if request.auth != null && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid;
        allow list: if request.auth != null && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid;
        allow create: if request.auth != null && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid;
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
